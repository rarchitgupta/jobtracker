{
  "manifest_version": 3,
  "name": "Job Tracker",
  "version": "2.0.0",
  "description": "Track job applications from any job board",
  "permissions": ["activeTab", "scripting", "cookies", "storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:3000/*",
    "https://refined-urchin-77.clerk.accounts.dev/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Track this job"
  }
}
